<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cancellation_Requires_Reason</fullName>
    <active>true</active>
    <description>Require cancellation reason when booking is cancelled</description>
    <errorConditionFormula>ISCHANGED(Booking_Status__c) &amp;&amp;
ISPICKVAL(Booking_Status__c, &quot;Cancelled&quot;) &amp;&amp;
ISBLANK(Cancellation_Reason__c)</errorConditionFormula>
    <errorDisplayField>Cancellation_Reason__c</errorDisplayField>
    <errorMessage>Cancellation reason is required</errorMessage>
</ValidationRule>
