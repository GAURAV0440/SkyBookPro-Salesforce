<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Booking_Date_Must_Be_Future</fullName>
    <active>true</active>
    <description>Prevent bookings for past flights</description>
    <errorConditionFormula>Flight__r.Departure_DateTime__c &lt;= NOW()</errorConditionFormula>
    <errorMessage>Departure must be a future date</errorMessage>
</ValidationRule>
