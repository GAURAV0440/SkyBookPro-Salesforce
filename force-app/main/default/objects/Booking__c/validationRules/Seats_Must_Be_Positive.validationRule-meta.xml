<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Seats_Must_Be_Positive</fullName>
    <active>true</active>
    <description>Prevent invalid seat counts</description>
    <errorConditionFormula>Number_of_Seats__c &lt; 1</errorConditionFormula>
    <errorDisplayField>Number_of_Seats__c</errorDisplayField>
    <errorMessage>At least 1 seat required</errorMessage>
</ValidationRule>
