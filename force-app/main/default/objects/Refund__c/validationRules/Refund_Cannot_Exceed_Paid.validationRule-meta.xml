<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Refund_Cannot_Exceed_Paid</fullName>
    <active>true</active>
    <description>Refund amount cannot exceed booking amount</description>
    <errorConditionFormula>Refund_Amount__c &gt; Booking__r.Total_Amount__c</errorConditionFormula>
    <errorDisplayField>Refund_Amount__c</errorDisplayField>
    <errorMessage>Refund amount cannot exceed booking total amount</errorMessage>
</ValidationRule>
