<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Passport_Required_International</fullName>
    <active>true</active>
    <description>Passport required for international flights</description>
    <errorConditionFormula>ISBLANK(Passport_Number__c) &amp;&amp;
Booking__r.Flight__r.Is_International__c = TRUE</errorConditionFormula>
    <errorDisplayField>Passport_Number__c</errorDisplayField>
    <errorMessage>Passport number required for international flights</errorMessage>
</ValidationRule>
